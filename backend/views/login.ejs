<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Login</title>
  <style>
    body {
      font-family: sans-serif;
      display: flex;
      height: 100vh;
      justify-content: center;
      align-items: center;
      background-color: #f7f7f7;
      margin: 0;
    }

    .box {
      padding: 20px 30px;
      border: 1px solid #ccc;
      border-radius: 10px;
      background-color: #fff;
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
      width: 100%;
      max-width: 400px;
    }

    h2 {
      text-align: center;
      margin-bottom: 20px;
    }

    input, button {
      display: block;
      margin: 10px 0;
      width: 100%;
      padding: 10px;
      border-radius: 5px;
      border: 1px solid #aaa;
      font-size: 16px;
    }

    button {
      background-color: #007bff;
      color: white;
      border: none;
      cursor: pointer;
    }

    button:hover {
      background-color: #0056b3;
    }

    .error {
      color: red;
      margin-bottom: 10px;
      text-align: center;
    }

    .link {
      text-align: center;
      margin-top: 10px;
    }

    a {
      text-decoration: none;
      color: #007bff;
    }

    a:hover {
      text-decoration: underline;
    }
  </style>
</head>
<body>
  <div class="box">
    <h2>Login</h2>

    <% if (error) { %>
      <p class="error"><%= error %></p>
    <% } %>

    <form method="POST" action="/login" onsubmit="disableButton()">
      <input type="email" name="email" placeholder="Enter email" required />
      <input type="date" name="dob" placeholder="Enter Date of Birth" required />
      <button type="submit" id="loginBtn">Login</button>
    </form>

    <div class="link">
      <p><a href="/">Register</a></p>
    </div>
  </div>

  <script>
    function disableButton() {
      const btn = document.getElementById("loginBtn");
      btn.disabled = true;
      btn.innerText = "Logging in...";
    }
  </script>
</body>
</html>
