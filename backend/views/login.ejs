<!DOCTYPE html>
<html>
<head>
  <title>Login</title>
  <style>
    body { font-family: sans-serif; display: flex; height: 100vh; justify-content: center; align-items: center; background-color: #f7f7f7; }
    .box { padding: 20px; border: 1px solid #ccc; border-radius: 8px; background-color: #fff; box-shadow: 0 0 10px rgba(0,0,0,0.1); }
    input, button { display: block; margin: 10px 0; width: 100%; padding: 8px; border-radius: 4px; border: 1px solid #aaa; }
    .error { color: red; margin-bottom: 10px; }
    a { text-decoration: none; color: #007bff; }
  </style>
</head>
<body>
  <div class="box">
    <h2>Login</h2>
    <% if (error) { %>
      <p class="error"><%= error %></p>
    <% } %>
    <form method="POST" action="/login">
      <input type="text" name="email" placeholder="Enter email" required />
      <input type="date" name="dob" required />
      <button type="submit">Login</button>
    </form>
    <p><a href="/">Register</a></p>
  </div>
</body>
</html>
